#!/usr/bin/env bash
# auto_resume.sh — run an agentic loop unattended, and when Claude Code hits a
# usage/rate limit, wait until the window resets and continue automatically.
#
# Why this exists: Claude Code does NOT yet auto-resume after a usage-limit
# reset (open feature requests anthropics/claude-code #36320, #35744, #18980).
# It DOES print the reset time when you hit the limit. This wrapper detects the
# limit, sleeps until reset + a margin, then relaunches a fresh session that
# reads PROGRESS.md and picks up exactly where it stopped. Durable state in
# PROGRESS.md is what makes "continue automatically" safe — the loop never
# loses its place.
#
# Edit the three CONFIG values, then: chmod +x scripts/auto_resume.sh && ./scripts/auto_resume.sh

set -uo pipefail

# ---- CONFIG ---------------------------------------------------------------
PROMPT='Read CLAUDE.md, LOOP.md, PROGRESS.md. Continue the next unfinished item in PROGRESS.md. Run the verification check after each change and show its output. Update PROGRESS.md before stopping. When every item is checked off and the full check passes, print exactly: ALL ITEMS COMPLETE. If you hit the usage limit, leave PROGRESS.md mid-task with the exact next step and stop.'
MODEL="claude-sonnet-4-6"                       # tier for the driver session (see references/model-routing.md)
PERMISSION_MODE="acceptEdits"                   # unattended: don't block on prompts. .claude/settings.json deny-list still applies.
DONE_MARKER="ALL ITEMS COMPLETE"                # loop prints this exact string when fully done
MAX_RESUMES=20                                  # safety cap on reset cycles before giving up
FALLBACK_WAIT_SECONDS=$((5 * 60 * 60 + 300))    # used only if no reset time can be parsed: 5h window + 5m margin
RESET_MARGIN_SECONDS=120                         # extra wait after the parsed reset time
LOG="scripts/auto_resume.log"
# ---------------------------------------------------------------------------

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"; }

# Sleep until a reset moment found in Claude's output, else the fallback window.
# Recognizes patterns like: "resets at 3pm", "resets at 15:00", "try again at 2026-06-16T20:00:00Z".
wait_for_reset() {
  local out="$1" reset_epoch now_epoch sleep_secs
  # ISO 8601 timestamp (most reliable, e.g. from API 429 bodies)
  local iso
  iso="$(grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}[Zz0-9:+-]*' <<<"$out" | head -1)"
  # "retry-after: N" seconds (API rate limit)
  local retry_after
  retry_after="$(grep -oiE 'retry[- ]after[": ]+[0-9]+' <<<"$out" | grep -oE '[0-9]+' | head -1)"
  # "resets at 3pm" / "resets at 15:00" (subscription usage limit)
  local clock
  clock="$(grep -oiE 'reset[s]?[^0-9]{0,12}([0-9]{1,2}(:[0-9]{2})?\s?(am|pm)?)' <<<"$out" | grep -oiE '[0-9]{1,2}(:[0-9]{2})?\s?(am|pm)?' | head -1)"

  now_epoch="$(date +%s)"
  if [[ -n "$iso" ]] && reset_epoch="$(date -d "$iso" +%s 2>/dev/null || date -jf '%Y-%m-%dT%H:%M:%S' "${iso%%[Zz]*}" +%s 2>/dev/null)"; then
    :
  elif [[ -n "$retry_after" ]]; then
    reset_epoch=$(( now_epoch + retry_after ))
  elif [[ -n "$clock" ]] && reset_epoch="$(date -d "$clock" +%s 2>/dev/null)"; then
    # if the parsed clock time is in the past, it means tomorrow
    [[ "$reset_epoch" -le "$now_epoch" ]] && reset_epoch=$(( reset_epoch + 86400 ))
  else
    reset_epoch=$(( now_epoch + FALLBACK_WAIT_SECONDS ))
  fi

  sleep_secs=$(( reset_epoch - now_epoch + RESET_MARGIN_SECONDS ))
  [[ "$sleep_secs" -lt 60 ]] && sleep_secs=60
  log "Usage limit hit. Waiting ${sleep_secs}s (until ~$(date -d "@$(( now_epoch + sleep_secs ))" '+%H:%M' 2>/dev/null || echo 'reset')) then resuming."
  sleep "$sleep_secs"
}

resumes=0
while :; do
  log "Launching loop session (resume #$resumes)."
  # --continue resumes the same conversation when possible; the prompt also
  # re-grounds from PROGRESS.md so a fresh session works identically.
  out="$(claude --continue -p "$PROMPT" --model "$MODEL" --permission-mode "$PERMISSION_MODE" --output-format text 2>&1)"
  status=$?
  echo "$out" | tail -40 | tee -a "$LOG" >/dev/null

  if grep -qiE 'usage limit|rate limit|limit reached|429|too many requests|resets? at|out of (tokens|usage)' <<<"$out"; then
    resumes=$(( resumes + 1 ))
    if [[ "$resumes" -gt "$MAX_RESUMES" ]]; then
      log "Hit MAX_RESUMES ($MAX_RESUMES). Stopping. Resume manually with this same script."
      exit 1
    fi
    wait_for_reset "$out"
    continue
  fi

  if grep -qF "$DONE_MARKER" <<<"$out"; then
    log "Loop reported done ($DONE_MARKER). Exiting."
    exit 0
  fi

  if [[ "$status" -ne 0 ]]; then
    log "Session exited non-zero ($status) without a recognized limit message. Stopping for inspection — state is in PROGRESS.md."
    exit "$status"
  fi

  # Clean exit, not done, no limit: re-launch to keep working.
  log "Session ended without DONE_MARKER and without a limit. Re-launching to continue."
done
