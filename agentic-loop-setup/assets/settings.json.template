{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(bash scripts/verify.sh)",
      "Bash(bash scripts/*.sh)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash([VERIFY_COMMAND])",
      "Bash([BUILD_COMMAND])",
      "Bash([LINT_COMMAND])",
      "Bash([TYPE_CHECK_COMMAND])"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash([DEPLOY_COMMAND] *)",
      "Bash(npm publish *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
